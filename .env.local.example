# Rentar — Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Base URL for the Rentar Backend REST API.
# Use /api for the Next.js mock routes during local development.
NEXT_PUBLIC_API_URL=/api

# ---------------------------------------------------------------------------
# Stellar Network
# ---------------------------------------------------------------------------
# "testnet" | "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# The deployed Soroban rent-vault contract address.
NEXT_PUBLIC_CONTRACT_ID=CDUMMYCONTRACTIDREPLACEME

# Horizon RPC endpoint used only for balance lookups in the wallet view.
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ---------------------------------------------------------------------------
# Demo Mode  (opt-in)
# ---------------------------------------------------------------------------
# Set to "true" to enable a fully local mock session when the backend is
# intentionally unavailable (e.g. during UI-only demos / offline development).
#
# WARNING: demo mode bypasses real SEP-10 authentication.  The generated JWT
# is a trivially forgeable base64 string that no real backend will accept.
# NEVER set this to "true" in a production deployment.
#
# Default: unset (disabled).  Real auth errors will propagate as expected.
NEXT_PUBLIC_DEMO_MODE=

# ---------------------------------------------------------------------------
# Database (server-side only — not exposed to the browser)
# ---------------------------------------------------------------------------
# Only required when running the local mock API routes that use PostgreSQL.
# Leave blank when pointing NEXT_PUBLIC_API_URL at a real Rentar backend.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rentar
